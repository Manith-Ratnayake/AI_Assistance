@page "/"
@inject IJSRuntime JSRuntime
@using FlintecAIAssistant.Components.Models;
@using FlintecAIAssistant.Components.Pages;
@using System.Linq;
@using Microsoft.JSInterop;
@using System.Globalization
@using Microsoft.Extensions.Localization
@using FlintecAIAssistant.Components.Data


<div class="app-shell">

    <aside class="sidebar @(isBVisible ? "sidebar-open" : "sidebar-closed")">

        @if (isBVisible)
        {
            <div class="sidebar-scroll-content">

            <div class="sidebar-top">

                <div class="brand-row">
                    <h6 class="brand-title">Flintec</h6>

                    <button class="icon-button tooltip-button tooltip-left-open"
                            @onclick="bOff"
                            data-tooltip="Close sidebar">
                        <img src="WebIcons/sidebar.png" class="sidebar-icon" alt="Sidebar" />
                    </button>
                </div>

                <button class="new-chat-button" @onclick="CreateNewConversation">
                    <img src="WebIcons/new.png" class="new-chat-icon" alt="New Chat" />
                    <span>New Chat</span>
                </button>

                <button class="saved-responses-button" @onclick="OpenSavedResponses">
                    <img src="WebIcons/save.png" class="saved-responses-icon" alt="Saved Responses" />
                    <span>Saved Responses</span>
                </button>

            </div>

            <div class="tabs-area">

                <div class="sidebar-section-label recents-section-label">
                    Recents
                </div>
                @foreach (var dict in userConversation.conversations.Select((conversation, listIndex) => new { conversation, listIndex }).Reverse())
                {
                    string firstMessage = dict.conversation.FirstOrDefault()?.Content ?? "New Chat";
                    string title = firstMessage.Length > 27 ? firstMessage.Substring(0, 27) : firstMessage;
                    bool hasUnread = unreadConversationIndexes.Contains(dict.listIndex);

                    <div class="chat-tab-wrapper">

                        <div class="chat-tab @(userConversation.pointingTab == dict.listIndex ? "chat-tab-active" : "")"
                                @onclick="() => GetConversation(dict.listIndex)">

                            <span class="chat-tab-title">@title</span>

                            <span class="chat-unread-dot @(hasUnread ? "chat-unread-dot-visible" : "")"></span>

                            <button class="tab-options-button"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => TogglePopup(dict.listIndex)"
                                    aria-label="Conversation options">
                                <span class="tab-options-dots">⋯</span>
                            </button>

                        </div>

                        @if (popupIndex == dict.listIndex)
                        {
                            <div class="chat-popup" @onclick:stopPropagation="true">

                                <button class="popup-item" @onclick="() => RenameConversation(dict.listIndex)">
                                    <img src="WebIcons/edit.png" class="popup-icon" />
                                    <span>Rename</span>
                                </button>

                                <button class="popup-item danger" @onclick="() => DeleteConversationAndClose(dict.listIndex)">
                                    <img src="WebIcons/delete.png" class="popup-icon delete-popup-icon" />
                                    <span>Delete</span>
                                </button>

                            </div>
                        }

                    </div>
                }

            </div>

            </div>

            <div class="sidebar-bottom">

                <button type="button"
                        class="sidebar-profile-row"
                        data-bs-toggle="modal"
                        data-bs-target="#exampleModal">

                    <div class="sidebar-profile-logo">
                        @GetInitials(personName)
                    </div>

                    <div class="sidebar-profile-info">
                        <div class="sidebar-profile-name">
                            @personName
                        </div>

                        <div class="sidebar-profile-subtitle">
                            Settings
                        </div>
                    </div>

                </button>

            </div>
        }

    </aside>

    @if (isBVisible)
    {
        <div class="mobile-sidebar-backdrop" @onclick="bOff"></div>
    }

    @if (popupIndex >= 0)
    {
        <div class="popup-outside-click-catcher" @onclick="CloseConversationPopup"></div>
    }

    <main class="main-area @(isBVisible ? "main-sidebar-open" : "main-full")">

        @if (!isBVisible)
        {
            <button class="mobile-menu-button"
                    @onclick="bOff"
                    aria-label="Open sidebar">
                <span></span>
                <span></span>
                <span></span>
            </button>
        }

        @if (!isBVisible)
        {
            <div class="chatgpt-left-rail">

                <div class="rail-top">

                    <button class="rail-icon-button tooltip-button logo-swap-button"
                            @onclick="bOff"
                            data-tooltip="Open sidebar">
                        <img src="WebIcons/flintec_logo.png" class="rail-icon rail-logo-default" alt="Logo" />
                        <img src="WebIcons/sidebar.png" class="rail-icon rail-logo-hover" alt="Open Sidebar" />
                    </button>

                    <button class="rail-icon-button tooltip-button"
                            @onclick="CreateNewConversation"
                            data-tooltip="New chat">
                        <img src="WebIcons/new.png" class="rail-icon" alt="New Chat" />
                    </button>

                    <button class="rail-icon-button tooltip-button"
                            @onclick="OpenSavedResponses"
                            data-tooltip="Saved responses">
                        <img src="WebIcons/save.png" class="rail-icon" alt="Saved Responses" />
                    </button>

                </div>

                <div class="rail-bottom">

                    <button type="button"
                            class="rail-profile-button tooltip-button"
                            data-tooltip="Settings"
                            data-bs-toggle="modal"
                            data-bs-target="#exampleModal">
                        @GetInitials(personName)
                    </button>

                </div>

            </div>
        }

        @if (isSavedResponsesView)
        {
            <div class="saved-responses-page">

                <div class="saved-responses-header">
                    <h2>Saved Responses</h2>
                    <p>Responses you saved will appear here.</p>
                </div>

                @if (savedResponses.Count == 0)
                {
                    <div class="saved-empty-state">
                        <img src="WebIcons/save.png" class="saved-empty-icon" alt="Saved" />
                        <h3>No saved responses yet</h3>
                        <p>Click the save icon under any assistant response to save it here.</p>
                    </div>
                }
                else
                {
                    <div class="saved-responses-list">

                        @foreach (var saved in savedResponses.Select((response, index) => new { response, index }))
                        {
                            <div class="saved-response-card">

                                <div class="saved-response-card-header">
                                    <span>Saved Response @(saved.index + 1)</span>

                                    <button class="assistant-action-button assistant-action-tooltip"
                                            @onclick="async () => await CopySavedResponse(saved.response, saved.index)"
                                            data-action-tooltip="Copy response"
                                            aria-label="Copy saved response">
                                        <img src="@(copySavedTickIndexes.Contains(saved.index) ? "WebIcons/tick.png" : "WebIcons/copy.png")"
                                             class="assistant-action-icon"
                                             alt="Copy" />
                                    </button>
                                </div>

                                <div class="saved-response-text">
                                    @saved.response
                                </div>

                            </div>
                        }

                    </div>
                }

            </div>
        }
        else if (messages?.Count > 0)
        {
            <div class="chat-page @(isSourcesPanelOpen ? "chat-page-with-sources" : "")">

                <div class="chat-main-column">

                <div class="messagesScrollArea" @ref="messagesScrollAreaRef">

                    @foreach (var item in messages.Select((message, index) => new { message, index }))
                    {
                        @if (item.message.Role == "user")
                        {
                            <div class="message-row user-message-row">
                                <div class="message-content user-message-content">

                                    <div class="user-message-wrap">

                                        <div class="user-bubble">
                                            @item.message.Content
                                        </div>

                                        <div class="user-message-actions">

                                            <button class="user-message-action-button user-action-tooltip"
                                                    @onclick="async () => await CopyUserMessage(item.message.Content, item.index)"
                                                    data-user-action-tooltip="Copy"
                                                    aria-label="Copy message">
                                                <img src="@(copyTickMessageIndexes.Contains(item.index) ? "WebIcons/tick.png" : "WebIcons/copy.png")"
                                                     class="user-message-action-icon"
                                                     alt="Copy" />
                                            </button>

                                            <button class="user-message-action-button user-action-tooltip danger-user-action"
                                                    @onclick="() => DeleteUserMessage(item.index)"
                                                    data-user-action-tooltip="Delete"
                                                    aria-label="Delete message">
                                                <img src="WebIcons/delete.png"
                                                     class="user-message-action-icon delete-user-action-icon"
                                                     alt="Delete" />
                                            </button>

                                        </div>

                                    </div>

                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="message-row assistant-message-row">
                                <div class="message-content assistant-message-content">

                                    <div class="assistant-logo">
                                        <img src="WebIcons/flintec_logo.png" class="assistant-logo-img" />
                                    </div>

                                    <div class="assistant-message-body">

                                        @if (IsCurrentStreamingAssistantMessage(item.index, item.message) && string.IsNullOrWhiteSpace(item.message.Content))
                                        {
                                            <div class="thinking-dots-only">
                                                <span class="thinking-dot"></span>
                                                <span class="thinking-dot"></span>
                                                <span class="thinking-dot"></span>
                                            </div>
                                        }
                                        else if (IsConnectionErrorMessage(item.message.Content))
                                        {
                                            <div class="connection-error-toast message-error-toast">
                                                <div class="connection-error-icon">!</div>
                                                <div class="connection-error-text">
                                                    @item.message.Content
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="assistant-text">
                                                @item.message.Content
                                            </div>
                                        }

                                        @if (!IsCurrentStreamingAssistantMessage(item.index, item.message) && !string.IsNullOrWhiteSpace(item.message.Content))
                                        {
                                            <div class="assistant-actions">

                                                <button class="assistant-action-button assistant-action-tooltip"
                                                        @onclick="async () => await CopyAssistantMessage(item.message.Content, item.index)"
                                                        data-action-tooltip="Copy response"
                                                        aria-label="Copy response">
                                                    <img src="@(copyTickMessageIndexes.Contains(item.index) ? "WebIcons/tick.png" : "WebIcons/copy.png")"
                                                         class="assistant-action-icon"
                                                         alt="Copy" />
                                                </button>

                                                <button class="assistant-action-button assistant-action-tooltip"
                                                        @onclick="async () => await SaveCurrentConversation(item.index)"
                                                        data-action-tooltip="Save response"
                                                        aria-label="Save response">
                                                    <img src="@(saveTickMessageIndexes.Contains(item.index) ? "WebIcons/tick.png" : "WebIcons/save.png")"
                                                         class="assistant-action-icon"
                                                         alt="Save" />
                                                </button>

                                                <button class="assistant-action-button assistant-action-tooltip"
                                                        @onclick="async () => await ReloadAssistantMessage(item.index)"
                                                        data-action-tooltip="Try again"
                                                        aria-label="Try again">
                                                    <img src="WebIcons/reload.png" class="assistant-action-icon reload-action-icon" alt="Reload" />
                                                </button>

                                                <button class="assistant-source-button"
                                                        @onclick="() => ShowSources(item.index)"
                                                        aria-label="Sources">
                                                    <img src="WebIcons/sources.png" class="assistant-source-icon" alt="Sources" />
                                                    <span>Sources</span>
                                                </button>

                                            </div>
                                        }

                                    </div>

                                </div>
                            </div>
                        }
                    }

                </div>

                @if (isAssistantStreaming && showScrollDownButton)
                {
                    <button class="floating-thinking-button"
                            @onclick="ScrollChatToBottom"
                            aria-label="Scroll to latest response">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                }
                else if (!isAssistantStreaming)
                {
                    <button class="scroll-down-button @(showScrollDownButton ? "scroll-down-button-visible" : "")"
                            @onclick="ScrollChatToBottom"
                            aria-label="Scroll to bottom">
                        <i class="bi bi-arrow-down"></i>
                    </button>
                }

                <div class="input-area chat-bottom-input-area">
                    <div class="input-holder chat-input-holder">

                        <textarea class="textarAreaPlaceHolder"
                                  @bind="userQuestion"
                                  placeholder="Ask Anything"
                                  rows="1"
                                  oninput="adjustHeight(this)">
                        </textarea>

                        <button class="send-button send-tooltip-button"
                                @onclick="HandleSendOrStopButtonClick"
                                data-tooltip="@(isAssistantStreaming ? "Stop answering" : "Send Prompt")">
                            @if (isAssistantStreaming)
                            {
                                <span class="stop-square-icon"></span>
                            }
                            else
                            {
                                <img src="WebIcons/up_arrow.png" class="send-icon" alt="Submit" />
                            }
                        </button>

                    </div>
                </div>

                <div class="footer-note"></div>

                </div>

                <aside class="sources-inline-area @(isSourcesPanelOpen ? "sources-inline-area-open" : "sources-inline-area-closed")">

                        <div class="sources-right-header">

                            <div class="sources-title-area">
                                <h2>Sources</h2>
                                <p>References used for this response</p>
                            </div>

                            <button class="sources-close-button"
                                    @onclick="CloseSourcesPanel"
                                    aria-label="Close sources">
                                ×
                            </button>

                        </div>

                        <div class="sources-response-preview">

                            <div class="sources-response-label">
                                Response sources
                            </div>

                            <div class="sources-response-text">
                                These documents were used to support the assistant response.
                            </div>

                        </div>

                        <div class="sources-list">

                            @foreach (var source in GetSelectedSources())
                            {
                                <button class="source-card" type="button">

                                    <div class="source-card-top">

                                        <div class="source-document-icon">
                                            <span></span>
                                        </div>

                                        <div class="source-card-main">

                                            <div class="source-document-name">
                                                @source.DocumentName
                                            </div>

                                            <div class="source-document-meta">
                                                Page @source.PageNumber
                                            </div>

                                        </div>

                                        <div class="source-page-pill">
                                            p. @source.PageNumber
                                        </div>

                                    </div>

                                    <div class="source-snippet">
                                        @source.Snippet
                                    </div>

                                </button>
                            }

                        </div>

                    </aside>

            </div>
        }
        else
        {
            <div class="home-page">

                <div class="home-center">

                    <div class="home-greeting-wrap">
                        <p class="AnimationText SomeTexTo home-title">
                            How Can I Help You?
                        </p>
                    </div>

                    <div class="input-holder home-input-holder">

                        <textarea class="textarAreaPlaceHolder"
                                  @bind="userQuestion"
                                  placeholder="Ask Anything"
                                  rows="1"
                                  oninput="adjustHeight(this)">
                        </textarea>

                        <button class="send-button send-tooltip-button"
                                @onclick="HandleSendOrStopButtonClick"
                                data-tooltip="@(isAssistantStreaming ? "Stop answering" : "Send Prompt")">
                            @if (isAssistantStreaming)
                            {
                                <span class="stop-square-icon"></span>
                            }
                            else
                            {
                                <img src="WebIcons/up_arrow.png" class="send-icon" alt="Submit" />
                            }
                        </button>

                    </div>

                    <div class="suggestions-area">

                        @foreach (var suggestion in suggestions)
                        {
                            <button class="SuggestionBlock suggestion-block"
                                    @onclick="() => UpdateTheSearchBar(suggestion)">
                                @suggestion
                            </button>
                        }

                    </div>

                </div>

            </div>
        }

    </main>

</div>



<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content settings-modal">

            <div class="settings-header">
                <h1 class="settings-title">Settings</h1>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>
            </div>

            <div class="modal-body">
                <Settings />
            </div>

            <div class="settings-footer">
            </div>

        </div>
    </div>
</div>








<style>


* { box-sizing: border-box; }
.app-shell { --background1-color: #212121; --background2-color: #212121; --background3-color: #2f2f2f; --background4-color: #3a3a3a; --background5-color: #424242; --font-color: #ececec; --font-muted-color: #b4b4b4; --border-color: rgba(255, 255, 255, 0.10); --border-color-strong: rgba(255, 255, 255, 0.16); --sidebar-divider-color: rgba(255, 255, 255, 0.08); --input-background: #2f2f2f; --input-background-focus: #343434; --suggestion-background: transparent; --suggestion-hover-background: #2f2f2f; --send-button-color: #ffffff; --send-icon-filter: brightness(0); --image-filter: brightness(0) invert(1); --sidebar-width: clamp(220px, 17vw, 300px); --rail-width: 64px; --chat-width: clamp(520px, 62vw, 780px); --message-width: clamp(520px, 62vw, 780px); --left-icon-button-size: 36px; --left-icon-size: 18px; width: 100%; height: 100vh; display: flex; overflow: hidden; background-color: var(--background1-color); color: var(--font-color); font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
.sidebar { height: 100vh; background-color: var(--background2-color); transition: width 0.3s ease; overflow: hidden; display: flex; flex-direction: column; position: relative; border-right: 1px solid var(--sidebar-divider-color); z-index: 600; }
.sidebar-scroll-content { flex: 1; min-height: 0; overflow-y: auto; overflow-x: hidden; padding-bottom: 14px; }
.sidebar-open { width: var(--sidebar-width); }
.sidebar-closed { width: 0; border-right: none; }
.popup-outside-click-catcher { position: fixed; top: 0; left: var(--sidebar-width); right: 0; bottom: 0; background-color: transparent; z-index: 500; }
.main-area { height: 100vh; background-color: var(--background1-color); transition: width 0.3s ease; overflow: hidden; position: relative; }
.main-sidebar-open { width: calc(100% - var(--sidebar-width)); }
.main-full { width: 100%; padding-left: var(--rail-width); }
.chatgpt-left-rail { position: fixed; top: 0; left: 0; width: var(--rail-width); height: 100vh; background-color: var(--background1-color); border-right: 1px solid var(--sidebar-divider-color); z-index: 100; display: flex; flex-direction: column; justify-content: space-between; align-items: center; padding: 14px 0; overflow: visible; }
.rail-top { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 12px; overflow: visible; }
.rail-bottom { width: 100%; display: flex; justify-content: center; align-items: center; overflow: visible; }
