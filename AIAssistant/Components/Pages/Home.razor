.new-chat-button:hover, .saved-responses-button:hover { background-color: var(--background3-color); }
.tabs-area { flex: none; overflow: visible; padding: 34px 0 10px 0; }
.sidebar-section-label { color: var(--font-color); font-size: 14px; font-weight: 600; padding: 0 16px; margin: 0 0 10px 0; letter-spacing: 0.1px; }
.recents-section-label { margin-top: 8px; margin-bottom: 12px; font-size: 14px; font-weight: 600; }
.chat-tab-wrapper { width: 100%; padding: 0 8px; position: relative; }
.chat-tab { width: 100%; min-height: 40px; padding: 0 6px 0 8px; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; gap: 8px; color: var(--font-color); cursor: pointer; font-size: 14px; transition: background-color 0.15s ease; position: relative; }
.chat-tab:hover { background-color: var(--background3-color); }
.chat-tab-active { background-color: #2a2a2a; }
.chat-tab-active:hover { background-color: #303030; }
.chat-tab-title { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1; color: var(--font-color); }
.chat-unread-dot { width: 7px; height: 7px; border-radius: 50%; background-color: #4f8cff; opacity: 0; flex-shrink: 0; margin-right: 6px; transition: opacity 0.15s ease; }
.chat-unread-dot-visible { opacity: 1; }
.chat-tab:hover .chat-unread-dot { opacity: 0; }
.tab-options-button { width: 30px; height: 30px; border: none; outline: none; border-radius: 50%; background-color: transparent; color: var(--font-muted-color); cursor: pointer; display: flex; justify-content: center; align-items: center; opacity: 0; flex-shrink: 0; transition: background-color 0.15s ease, opacity 0.15s ease, color 0.15s ease; }
.chat-tab:hover .tab-options-button, .chat-tab-active .tab-options-button { opacity: 1; }
.tab-options-button:hover { background-color: var(--background4-color); color: var(--font-color); }
.tab-options-dots { font-size: 22px; line-height: 1; transform: translateY(-2px); letter-spacing: -1px; }
.chat-popup { position: absolute; right: 16px; top: 38px; z-index: 1000; width: 140px; background-color: #2b2b2b; border: 1px solid var(--border-color); border-radius: 12px; padding: 6px; box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45); }
.popup-item { width: 100%; min-height: 34px; border: none; outline: none; border-radius: 8px; background-color: transparent; color: var(--font-color); display: flex; align-items: center; gap: 10px; padding: 0 8px; cursor: pointer; font-size: 14px; text-align: left; }
.popup-item:hover { background-color: var(--background4-color); }
.popup-item.danger { color: #ff6b6b; }
.popup-item.danger:hover { background-color: rgba(220, 70, 70, 0.25); }
