.rail-icon-button:hover, .icon-button:hover { background-color: var(--background3-color); }
.rail-icon-button:active, .icon-button:active { transform: scale(0.96); }
.rail-icon, .sidebar-icon, .new-chat-icon, .saved-responses-icon { width: var(--left-icon-size); height: var(--left-icon-size); object-fit: contain; filter: brightness(0) invert(1); opacity: 0.9; }
.rail-icon-button:hover .rail-icon, .icon-button:hover .sidebar-icon, .new-chat-button:hover .new-chat-icon, .saved-responses-button:hover .saved-responses-icon { opacity: 1; }
.logo-swap-button { position: relative; }
.rail-logo-default, .rail-logo-hover { position: absolute; width: var(--left-icon-size); height: var(--left-icon-size); object-fit: contain; transition: opacity 0.12s ease; }
.rail-logo-default { opacity: 1; filter: none; }
.rail-logo-hover { opacity: 0; filter: brightness(0) invert(1); }
.chatgpt-left-rail:hover .rail-logo-default { opacity: 0; filter: brightness(0); }
.chatgpt-left-rail:hover .rail-logo-hover { opacity: 1; }
.rail-profile-button { width: 30px; height: 30px; border: none; outline: none; border-radius: 50%; background-color: #ab68ff; color: white; font-size: 11px; font-weight: 600; cursor: pointer; transition: opacity 0.15s ease, transform 0.15s ease; }
.rail-profile-button:hover { opacity: 0.9; }
.rail-profile-button:active { transform: scale(0.96); }
.sidebar-top { padding: 14px 8px 10px 8px; display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }
.brand-row { display: flex; justify-content: space-between; align-items: center; min-height: 36px; margin-bottom: 4px; padding: 0 8px; }
.brand-title { margin: 0; color: var(--font-color); font-size: 20px; font-weight: 600; letter-spacing: 0.6px; }
