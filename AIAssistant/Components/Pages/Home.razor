<script>
    window.flintecChatScroll = {
    register: function (element, dotnetHelper) {
        if (!element) return;

        if (element._flintecChatScrollHandler) {
            element.removeEventListener("scroll", element._flintecChatScrollHandler);
        }

        element._flintecChatScrollHandler = function () {
            const distanceFromBottom = element.scrollHeight - element.scrollTop - element.clientHeight;
            const shouldShow = distanceFromBottom > 140;
            dotnetHelper.invokeMethodAsync("SetScrollDownButtonVisible", shouldShow);
        };

        element.addEventListener("scroll", element._flintecChatScrollHandler);
        element._flintecChatScrollHandler();
    },

    scrollToBottom: function (element) {
        if (!element) return;

        element.scrollTo({
            top: element.scrollHeight,
            behavior: "smooth"
        });
    }
};

</script>