@using Microsoft.Extensions.Localization
@using System.Globalization
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="settings-body">

    <div class="settings-field">
        <label>Name</label>

        <input class="settings-input"
               type="text"
               placeholder="Enter your name" />
    </div>

    <div class="settings-field">
        <label>Custom Instruction</label>

        <textarea class="settings-textarea"
                  placeholder="Write how you want the assistant to respond"></textarea>
    </div>

    <div class="settings-field">
        <label>Memory</label>

        <div class="memory-box">

            <div class="memory-item">
                <textarea class="memory-textarea"></textarea>
            </div>

            <div class="memory-item">
                <textarea class="memory-textarea"></textarea>
            </div>

            <div class="memory-item">
                <textarea class="memory-textarea"></textarea>
            </div>

            <div class="memory-item">
                <textarea class="memory-textarea"></textarea>
            </div>

            <div class="memory-item">
                <textarea class="memory-textarea"></textarea>
            </div>

        </div>
    </div>

</div>

<style>
    .settings-body {
        height: calc(100% - 64px);
        display: flex;
        flex-direction: column;
        gap: 22px;
        overflow: hidden;
    }

    .settings-field {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .settings-field label {
        color: #ececec;
        font-size: 14px;
        font-weight: 600;
    }

    .settings-input {
        width: 100%;
        height: 44px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        outline: none;
        border-radius: 10px;
        background-color: #2f2f2f;
        color: #ececec;
        padding: 0 14px;
        font-size: 14px;
        font-family: inherit;
    }

    .settings-textarea {
        width: 100%;
        height: 130px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        outline: none;
        border-radius: 10px;
        background-color: #2f2f2f;
        color: #ececec;
        padding: 14px;
        font-size: 14px;
        line-height: 1.5;
        font-family: inherit;
        resize: none;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .memory-box {
        width: 100%;
        height: 230px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 10px;
        background-color: #2f2f2f;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .memory-item {
        width: 100%;
        height: 46px;
        padding: 8px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        overflow: hidden;
    }

    .memory-item:last-child {
        border-bottom: none;
    }

    .memory-textarea {
        width: 100%;
        height: 30px;
        border: none;
        outline: none;
        resize: none;
        background-color: transparent;
        color: #ececec;
        font-size: 14px;
        line-height: 15px;
        font-family: inherit;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .settings-input::placeholder,
    .settings-textarea::placeholder,
    .memory-textarea::placeholder {
        color: #9b9b9b;
    }

    .settings-input:focus,
    .settings-textarea:focus,
    .memory-box:focus-within {
        border-color: rgba(255, 255, 255, 0.32);
        background-color: #343434;
    }

    .settings-textarea::-webkit-scrollbar,
    .memory-box::-webkit-scrollbar,
    .memory-textarea::-webkit-scrollbar {
        width: 7px;
    }

    .settings-textarea::-webkit-scrollbar-track,
    .memory-box::-webkit-scrollbar-track,
    .memory-textarea::-webkit-scrollbar-track {
        background: transparent;
    }

    .settings-textarea::-webkit-scrollbar-thumb,
    .memory-box::-webkit-scrollbar-thumb,
    .memory-textarea::-webkit-scrollbar-thumb {
        background: #606060;
        border-radius: 999px;
    }

    .settings-textarea::-webkit-scrollbar-thumb:hover,
    .memory-box::-webkit-scrollbar-thumb:hover,
    .memory-textarea::-webkit-scrollbar-thumb:hover {
        background: #777777;
    }

    .settings-textarea,
    .memory-box,
    .memory-textarea {
        scrollbar-width: thin;
        scrollbar-color: #606060 transparent;
    }

    @@media (max-width: 700px) {
        .settings-textarea {
            height: 110px;
        }

        .memory-box {
            height: 210px;
        }
    }
</style>